{
  "name": "@yucp/bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "tsc",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "bun run test:e2e",
    "test:e2e": "bun test ./test/e2e --timeout 300000",
    "test:e2e:ci": "bun test ./test/e2e --timeout 300000"
  },
  "dependencies": {
    "@yucp/providers": "workspace:*",
    "@yucp/shared": "workspace:*",
    "convex": "^1.32.0",
    "discord.js": "^14.15.0",
    "posthog-node": "^5.26.2"
  },
  "devDependencies": {
    "@infisical/sdk": "^4.0.6",
    "@types/bun": "^1.1.0",
    "bun-types": "^1.1.0",
    "playwright": "^1.53.0"
  }
}
